{
  "entities": {
    "Obra": {
      "title": "Obra",
      "description": "Uma obra em andamento registrada no sistema",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "cliente": { "type": "string" },
        "endereco": { "type": "string" },
        "responsavelTecnico": { "type": "string" },
        "dataInicio": { "type": "string" },
        "observacoes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "nome", "cliente", "responsavelTecnico", "ownerId", "createdAt"]
    },
    "Diario": {
      "title": "Diario",
      "description": "Um diário diário de ocorrências e progresso da obra",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "obraId": { "type": "string" },
        "data": { "type": "string" },
        "horario": { "type": "string" },
        "clima": { "type": "string" },
        "equipe": { "type": "string" },
        "atividades": { "type": "string" },
        "materiais": { "type": "string" },
        "ocorrencias": { "type": "string" },
        "observacoes": { "type": "string" },
        "assinatura": { "type": "string" },
        "gps": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "obraId", "data", "horario", "atividades", "ownerId", "createdAt"]
    },
    "Foto": {
      "title": "Foto",
      "description": "Uma foto associada a um diário de obra",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "diarioId": { "type": "string" },
        "obraId": { "type": "string" },
        "url": { "type": "string" },
        "legenda": { "type": "string" },
        "data": { "type": "string" },
        "horario": { "type": "string" },
        "gps": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "diarioId", "obraId", "url", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/obras/{obraId}": {
      "schema": "Obra",
      "description": "Obras do usuário"
    },
    "/obras/{obraId}/diarios/{diarioId}": {
      "schema": "Diario",
      "description": "Registros diários da obra"
    },
    "/obras/{obraId}/diarios/{diarioId}/fotos/{fotoId}": {
      "schema": "Foto",
      "description": "Fotos vinculadas a um diário de obra"
    }
  }
}
