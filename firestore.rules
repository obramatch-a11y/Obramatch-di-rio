rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Plano do usuario: escrito SOMENTE pelo servidor (service account).
    match /planos/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Consumo de IA: escrito SOMENTE pelo servidor; o dono pode ler o proprio.
    match /uso_ia/{docId} {
      allow read: if isSignedIn() && docId.matches('^' + request.auth.uid + '_.*$');
      allow write: if false;
    }

    // Perfil do usuario (vinculo Telegram). O cliente NAO pode escrever
    // campos de controle de uso/plano (iaUso legado, plano) -> anti-burla.
    match /usuarios/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['iaUso', 'plano']);
    }

    // Obras: cada usuario le e escreve apenas as proprias.
    // A checagem em list (resource nulo) permite a query filtrada por ownerId.
    match /obras/{obraId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow write: if isSignedIn()
        && (resource == null || resource.data.ownerId == request.auth.uid)
        && (request.resource == null || request.resource.data.ownerId == request.auth.uid);

      match /diarios/{diarioId} {
        allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
        allow write: if isSignedIn()
          && (resource == null || resource.data.ownerId == request.auth.uid)
          && (request.resource == null || request.resource.data.ownerId == request.auth.uid);

        match /fotos/{fotoId} {
          allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
          allow write: if isSignedIn()
            && (resource == null || resource.data.ownerId == request.auth.uid)
            && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
        }
      }
    }
  }
}
